<%- include('partials/header') %>

<div class="page-title">Administrative Portal & Security Audit Telemetry</div>

<div class="alert alert-warning">
  Restricted Area: Access granted to Administrator role (<code><%= user.username %></code>).
</div>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header">System User Directory</div>
      <table class="table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Full Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Balance</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <tr>
              <td><%= u.id %></td>
              <td><code><%= u.username %></code></td>
              <td><%= u.full_name %></td>
              <td><%= u.email %></td>
              <td><span class="badge <%= u.role === 'admin' ? 'badge-danger' : 'badge-secondary' %>"><%= u.role %></span></td>
              <td>$<%= u.balance.toFixed(2) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header">Real-time Telemetry Event Logs</div>
      <table class="table">
        <thead>
          <tr>
            <th>Vulnerability Module</th>
            <th>Total Attempts</th>
            <th>Total Solves</th>
            <th>Last Attempt Timestamp</th>
          </tr>
        </thead>
        <tbody>
          <% telemetry.forEach(t => { %>
            <tr>
              <td><strong><%= t.name %></strong> (<code><%= t.vuln_key %></code>)</td>
              <td><span style="font-weight: 700; color: var(--danger-red);"><%= t.attempt_count %></span></td>
              <td><span style="font-weight: 700; color: var(--success-green);"><%= t.solve_count %></span></td>
              <td><%= t.last_attempt || 'No attempts recorded' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
