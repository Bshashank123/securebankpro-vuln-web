<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>SecureBank Pro - Presentation Deck</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { background-color: #1a252f; color: #ffffff; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; overflow-x: hidden; }
    .presentation-container { max-width: 1000px; margin: 40px auto; padding: 0 20px; }
    .slide { display: none; background: #ffffff; color: #2c3e50; border-radius: 6px; padding: 40px; min-height: 520px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); position: relative; }
    .slide.active { display: block; animation: fadeIn 0.3s ease-in-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .slide-header { border-bottom: 2px solid #2980b9; padding-bottom: 15px; margin-bottom: 25px; }
    .slide-category { font-size: 11px; font-weight: 700; color: #2980b9; text-transform: uppercase; letter-spacing: 1px; }
    .slide-title { font-size: 24px; font-weight: 700; color: #1a252f; margin-top: 4px; }
    .slide-body { font-size: 16px; line-height: 1.7; color: #34495e; }
    .slide-body ul { padding-left: 24px; margin-top: 15px; }
    .slide-body li { margin-bottom: 14px; }
    .controls { display: flex; justify-content: space-between; align-items: center; margin-top: 25px; }
    .btn-nav { background: #2980b9; color: #fff; border: none; padding: 10px 24px; border-radius: 4px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; }
    .btn-nav:disabled { background: #7f8c8d; cursor: not-allowed; opacity: 0.6; }
    .counter { color: #d1d8e0; font-size: 14px; font-weight: 600; }
    .code-box { background: #f8f9fa; border: 1px solid #dcdfe3; padding: 12px; font-family: monospace; font-size: 13px; border-radius: 4px; color: #c0392b; margin: 10px 0; }
    .badge-attack { background: #e74c3c; color: #fff; padding: 3px 8px; border-radius: 3px; font-size: 12px; font-weight: 700; }
    .badge-secure { background: #27ae60; color: #fff; padding: 3px 8px; border-radius: 3px; font-size: 12px; font-weight: 700; }
  </style>
</head>
<body>

  <div class="presentation-container">
    <div style="margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center;">
      <a href="/" style="color: #3498db; text-decoration: none; font-weight: 600; font-size: 14px;">&laquo; Back to Portal</a>
      <a href="/SecureBank_Pro_Presentation.pptx" download class="btn-nav" style="background: #27ae60;">📥 Download PowerPoint (.pptx)</a>
    </div>

    <!-- SLIDE 1 -->
    <div class="slide active">
      <div class="slide-header">
        <div class="slide-category">Project Overview & Links</div>
        <div class="slide-title">SecureBank Pro</div>
      </div>
      <div class="slide-body">
        <p style="font-size: 18px; font-weight: 600; color: #2980b9; margin-bottom: 20px;">Intentionally Vulnerable Banking Portal & Security Education Lab</p>
        <div style="background: #f4f6f9; padding: 20px; border-radius: 4px; border-left: 4px solid #2980b9;">
          <p style="margin-bottom: 12px;"><strong>🌐 Live Deployment:</strong> <a href="https://securebankpro-vuln-web.vercel.app/" target="_blank">https://securebankpro-vuln-web.vercel.app/</a></p>
          <p style="margin: 0;"><strong>💻 GitHub Repository:</strong> <a href="https://github.com/Bshashank123/securebankpro-vuln-web" target="_blank">https://github.com/Bshashank123/securebankpro-vuln-web</a></p>
        </div>
      </div>
    </div>

    <!-- SLIDE 2 -->
    <div class="slide">
      <div class="slide-header">
        <div class="slide-category">Executive Project Summary</div>
        <div class="slide-title">Project Purpose & Core Vision</div>
      </div>
      <div class="slide-body">
        <p style="font-size: 17px; line-height: 1.8;">
          <strong>SecureBank Pro</strong> is an intentionally vulnerable, full-stack online banking web application engineered for cybersecurity education, vulnerability analysis, and web security defense comparison. Designed with a clean 2018 corporate enterprise aesthetic, the system features a dual-controller architecture that enables users to toggle dynamically between an Attack Mode (exposing six critical OWASP Top 10 vulnerabilities) and a Secure Mode (implementing enterprise-grade defensive mitigations), backed by a real-time telemetry engine that tracks security testing progress and exploit attempts across lab sessions.
        </p>
      </div>
    </div>

    <!-- SLIDE 3 -->
    <div class="slide">
      <div class="slide-header">
        <div class="slide-category">Technical Architecture</div>
        <div class="slide-title">System Stack & Design Philosophy</div>
      </div>
      <div class="slide-body">
        <ul>
          <li><strong>2018 Corporate Neutral Aesthetic:</strong> Clean, high-contrast palette (Slate `#f4f6f9`, Navy `#1a252f`, Steel Blue `#2980b9`), fast server-rendered EJS templates, zero emojis.</li>
          <li><strong>Backend Engine:</strong> Node.js with Express.js server-side controller architecture.</li>
          <li><strong>Dual Database System:</strong> SQLite3 database tracking core banking operations and session telemetry statistics.</li>
          <li><strong>Multi-Platform Deployment:</strong> Runs locally via Node.js, containerized via Docker Compose, and cloud-hosted on Vercel Serverless Functions.</li>
        </ul>
      </div>
    </div>

    <!-- SLIDE 4 -->
    <div class="slide">
      <div class="slide-header">
        <div class="slide-category">Core Innovation</div>
        <div class="slide-title">Dual-Mode Controller Engine</div>
      </div>
      <div class="slide-body">
        <ul>
          <li><strong>Dynamic Mode Switcher:</strong> Instantly switch between <span class="badge-attack">ATTACK MODE</span> and <span class="badge-secure">SECURE MODE</span> via the navigation bar.</li>
          <li><strong>Single-Route Evaluation:</strong> Endpoints inspect `req.session.isSecureMode` to execute vulnerable or mitigated code paths on identical URLs.</li>
          <li><strong>Side-by-Side Learning:</strong> Developers can test exploits in real time and verify how defensive implementations neutralize threats.</li>
        </ul>
      </div>
    </div>

    <!-- SLIDE 5 -->
    <div class="slide">
      <div class="slide-header">
        <div class="slide-category">Telemetry Engine</div>
        <div class="slide-title">Real-Time Progress & Exploit Tracking</div>
      </div>
      <div class="slide-body">
        <ul>
          <li><strong>Live Dashboard Counters:</strong> Tracks total lab sessions, total exploit attempts, and participants who have completed all 6 vulnerabilities.</li>
          <li><strong>Automated Solve Verification:</strong> Evaluates inbound payloads to record attempts and award COMPLETED status only when an attack succeeds in Attack Mode.</li>
          <li><strong>Administrative Audit Panel:</strong> Accessible via `/admin` for inspecting timestamped security telemetry logs.</li>
        </ul>
      </div>
    </div>

    <!-- SLIDE 6 -->
    <div class="slide">
      <div class="slide-header">
        <div class="slide-category">Vulnerability 1 / 6</div>
        <div class="slide-title">SQL Injection (SQLi)</div>
      </div>
      <div class="slide-body">
        <p><strong>Endpoint:</strong> <code>POST /login</code></p>
        <p><span class="badge-attack">Attack Mode:</span> Concatenates user input directly into SQL strings (`SELECT * FROM users WHERE username = '${username}'...`). Payload <code>admin' --</code> bypasses password verification.</p>
        <p><span class="badge-secure">Secure Mode:</span> Employs Parameterized Queries (`WHERE username = ? AND password = ?`), ensuring input special characters are treated purely as literal text.</p>
      </div>
    </div>

    <!-- SLIDE 7 -->
    <div class="slide">
      <div class="slide-header">
        <div class="slide-category">Vulnerability 2 / 6</div>
        <div class="slide-title">Weak Authentication & Brute-Force</div>
      </div>
      <div class="slide-body">
        <p><strong>Endpoint:</strong> <code>POST /login</code></p>
        <p><span class="badge-attack">Attack Mode:</span> Default administrative account (<code>admin/admin</code>) paired with zero login throttling or account lockout controls.</p>
        <p><span class="badge-secure">Secure Mode:</span> Tracks failed login attempts in the session, triggering account lockout after 5 consecutive failures.</p>
      </div>
    </div>

    <!-- SLIDE 8 -->
    <div class="slide">
      <div class="slide-header">
        <div class="slide-category">Vulnerability 3 / 6</div>
        <div class="slide-title">Stored Cross-Site Scripting (XSS)</div>
      </div>
      <div class="slide-body">
        <p><strong>Endpoint:</strong> <code>POST /profile/update</code> & <code>GET /profile</code></p>
        <p><span class="badge-attack">Attack Mode:</span> Stores unsanitized bio input in SQLite and renders raw HTML via EJS <code>&lt;%- user.about_me %&gt;</code>. Payload <code>&lt;script&gt;alert(1)&lt;/script&gt;</code> persistently executes JavaScript.</p>
        <p><span class="badge-secure">Secure Mode:</span> Enforces contextual HTML entity encoding via EJS <code>&lt;%= user.about_me %&gt;</code>, escaping tags safely into text literals.</p>
      </div>
    </div>

    <!-- SLIDE 9 -->
    <div class="slide">
      <div class="slide-header">
        <div class="slide-category">Vulnerability 4 / 6</div>
        <div class="slide-title">Insecure Direct Object Reference (IDOR)</div>
      </div>
      <div class="slide-body">
        <p><strong>Endpoint:</strong> <code>GET /transaction?id=...</code></p>
        <p><span class="badge-attack">Attack Mode:</span> Queries transaction receipts directly by database ID from URL parameters without checking user ownership. Standard user <code>john_doe</code> changing <code>?id=102</code> to <code>?id=104</code> accesses executive receipts.</p>
        <p><span class="badge-secure">Secure Mode:</span> Verifies session user ownership (<code>sender_id = user.id OR receiver_id = user.id</code>), returning 403 Forbidden on unauthorized requests.</p>
      </div>
    </div>

    <!-- SLIDE 10 -->
    <div class="slide">
      <div class="slide-header">
        <div class="slide-category">Vulnerability 5 / 6</div>
        <div class="slide-title">Cross-Site Request Forgery (CSRF)</div>
      </div>
      <div class="slide-body">
        <p><strong>Endpoint:</strong> <code>POST /transfer</code></p>
        <p><span class="badge-attack">Attack Mode:</span> Processes funds transfers based solely on ambient session cookies without verifying anti-CSRF state tokens. External sites host auto-submitting forms to drain accounts.</p>
        <p><span class="badge-secure">Secure Mode:</span> Generates per-session cryptographically signed <code>_csrf</code> tokens and validates token presence on form submissions.</p>
      </div>
    </div>

    <!-- SLIDE 11 -->
    <div class="slide">
      <div class="slide-header">
        <div class="slide-category">Vulnerability 6 / 6</div>
        <div class="slide-title">Unvalidated File Upload</div>
      </div>
      <div class="slide-body">
        <p><strong>Endpoint:</strong> <code>POST /profile/upload</code></p>
        <p><span class="badge-attack">Attack Mode:</span> Accepts arbitrary uploaded file extensions (<code>.txt</code>, <code>.html</code>, <code>.exe</code>) into a public directory using original filenames.</p>
        <p><span class="badge-secure">Secure Mode:</span> Enforces strict image MIME-type validation (<code>image/*</code>), restricts extensions (<code>.png</code>, <code>.jpg</code>), and renames files to randomized UUIDs.</p>
      </div>
    </div>

    <!-- SLIDE 12 -->
    <div class="slide">
      <div class="slide-header">
        <div class="slide-category">Conclusion</div>
        <div class="slide-title">Educational Impact & Deployment Summary</div>
      </div>
      <div class="slide-body">
        <ul>
          <li><strong>Local Execution:</strong> Standalone Node.js server (<code>npm start</code>).</li>
          <li><strong>Containerized Lab:</strong> Docker Compose setup for isolated deployment.</li>
          <li><strong>Cloud Serverless:</strong> Hosted on Vercel with dynamic <code>/tmp</code> SQLite storage.</li>
          <li><strong>Educational Value:</strong> An interactive hands-on lab demonstrating real-world web application security principles.</li>
        </ul>
      </div>
    </div>

    <!-- CONTROLS -->
    <div class="controls">
      <button class="btn-nav" id="prevBtn" onclick="changeSlide(-1)">&laquo; Previous</button>
      <span class="counter" id="slideCounter">Slide 1 of 12</span>
      <button class="btn-nav" id="nextBtn" onclick="changeSlide(1)">Next &raquo;</button>
    </div>

  </div>

  <script>
    let currentSlide = 0;
    const slides = document.querySelectorAll('.slide');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const counter = document.getElementById('slideCounter');

    function updateSlides() {
      slides.forEach((s, idx) => {
        s.classList.toggle('active', idx === currentSlide);
      });
      counter.textContent = `Slide ${currentSlide + 1} of ${slides.length}`;
      prevBtn.disabled = currentSlide === 0;
      nextBtn.disabled = currentSlide === slides.length - 1;
    }

    function changeSlide(direction) {
      currentSlide += direction;
      if (currentSlide < 0) currentSlide = 0;
      if (currentSlide >= slides.length) currentSlide = slides.length - 1;
      updateSlides();
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === ' ') changeSlide(1);
      if (e.key === 'ArrowLeft') changeSlide(-1);
    });

    updateSlides();
  </script>

</body>
</html>
