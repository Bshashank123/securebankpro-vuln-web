<%- include('partials/header') %>

<div class="page-title">Funds Transfer Portal</div>

<div class="row">
  <div class="col-6">
    <div class="card">
      <div class="card-header">Initiate Wire Transfer</div>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>

      <form action="/transfer" method="POST">
        <% if (isSecureMode && csrfToken) { %>
          <!-- SECURE MODE: Anti-CSRF Token Input -->
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>

        <div class="form-group">
          <label for="recipient">Recipient Account Username</label>
          <input type="text" id="recipient" name="recipient" class="form-control" placeholder="e.g. alice_smith" required>
        </div>

        <div class="form-group">
          <label for="amount">Transfer Amount ($ USD)</label>
          <input type="number" step="0.01" min="1" id="amount" name="amount" class="form-control" placeholder="0.00" required>
        </div>

        <div class="form-group">
          <label for="description">Payment Reference / Note</label>
          <input type="text" id="description" name="description" class="form-control" placeholder="e.g. Invoice payment">
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%;">Process Transfer</button>
      </form>
    </div>
  </div>

  <div class="col-6">
    <div class="card">
      <div class="card-header" style="font-size: 13px;">Vulnerability Focus: Cross-Site Request Forgery (CSRF)</div>
      <p style="font-size: 12px; color: var(--text-muted); line-height: 1.6;">
        <strong>Attack Mode:</strong> The endpoint <code>POST /transfer</code> accepts requests based strictly on ambient session cookies without an anti-CSRF token.<br><br>
        <strong>CSRF PoC Concept:</strong> An external site could execute a background request:<br>
        <code>&lt;form action="http://localhost:3000/transfer" method="POST"&gt;</code><br>
        <code>&lt;input type="hidden" name="recipient" value="attacker"&gt;</code><br>
        <code>&lt;input type="hidden" name="amount" value="500"&gt;</code><br>
        <code>&lt;/form&gt;</code><br><br>
        <strong>Secure Mode:</strong> Server validates per-session cryptographically signed <code>_csrf</code> token.
      </p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
